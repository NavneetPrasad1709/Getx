# GETX seller app — production env template (Vercel).

# Keep RELATIVE (same-origin proxy) — an absolute value breaks Safari cookies.
NEXT_PUBLIC_API_URL=/api/v1
# REQUIRED: the seller middleware session check + /api rewrite proxy here.
# If unset, the middleware falls back to localhost and every page redirects to
# login.
API_UPSTREAM_URL=https://api.getx.live
# Chat WebSocket connects to the API directly.
NEXT_PUBLIC_API_DIRECT_URL=https://api.getx.live

NEXT_PUBLIC_WEB_URL=https://getx.live
NEXT_PUBLIC_SELLER_URL=https://sell.getx.live
NEXT_PUBLIC_SITE_URL=https://sell.getx.live

# Seller payouts gate. Keep OFF (=false) until KYC + checkout are live —
# enabling lets verified sellers request real withdrawals.
NEXT_PUBLIC_PAYOUTS_LIVE=false

NEXT_PUBLIC_SENTRY_DSN=
