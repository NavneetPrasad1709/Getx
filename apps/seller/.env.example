# GETX seller app — local dev env template.
#
# Same-origin proxy: browser → /api/v1 → (Next rewrite) → API_UPSTREAM_URL.
# NEXT_PUBLIC_API_URL MUST include the /api/v1 path (or be the relative proxy
# path below) — without it every seller API call 404s and the dashboard never
# loads.
NEXT_PUBLIC_API_URL=/api/v1
# Server-side: the seller middleware session check + /api rewrite proxy here.
API_UPSTREAM_URL=http://localhost:4000
# Chat WebSocket connects to the API directly.
NEXT_PUBLIC_API_DIRECT_URL=http://localhost:4000

NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SELLER_URL=http://localhost:3001

# Seller payouts gate. Keep OFF (=false) until KYC verification and checkout are
# live — enabling lets verified sellers request real withdrawals.
NEXT_PUBLIC_PAYOUTS_LIVE=false
