PORT=4000
NODE_ENV=development

# Neon Postgres — pooled (pgbouncer) endpoint.
# Get from https://console.neon.tech (project dashboard → Connection Details).
# Direct (non-pooled) URL only needed in packages/database/.env for `prisma migrate`.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/getx?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=1"

# JWT_SECRET set in Prompt 4 (Auth)
