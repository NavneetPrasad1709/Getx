PORT=4000
NODE_ENV=development

# Neon Postgres — pooled (pgbouncer) endpoint.
# Get from https://console.neon.tech (project dashboard → Connection Details).
# Direct (non-pooled) URL only needed in packages/database/.env for `prisma migrate`.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/getx?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=10&pool_timeout=20"

# JWT (Prompt 4) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="generate-with-crypto-randomBytes-32"
JWT_REFRESH_SECRET="generate-with-crypto-randomBytes-32-different"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Encryption (for future PII)
PII_ENCRYPTION_KEY="generate-32-byte-hex-key"

# Email (Resend) — leave blank for dev (console fallback).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="GETX <noreply@getx.live>"

# Cookies — empty = host-only (localhost). In prod: ".getx.gg".
COOKIE_DOMAIN=""

# Frontend URLs (CORS allowlist)
WEB_URL="http://localhost:3000"
SELLER_URL="http://localhost:3001"
ADMIN_URL="http://localhost:3002"

# Cloudflare R2 (image uploads) — leave empty in dev to use base64 data-URL fallback.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="getx-uploads"
R2_PUBLIC_URL=""

# Payments (Paddle) — leave PADDLE_API_KEY empty in dev to use mock provider.
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_ENV="sandbox"

# Public-facing URL of this API (used in mock checkout redirect)
API_URL="http://localhost:4000"
