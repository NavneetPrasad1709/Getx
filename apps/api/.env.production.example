# GETX API — production env template.
# Copy to your hosting provider's secret store (Railway/Render dashboard).
# Never commit a populated copy — secrets only.
#
# ─── Generate the 4 local secrets first (PowerShell on Windows) ────
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"  # JWT_ACCESS_SECRET
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"  # JWT_REFRESH_SECRET (re-run, different value!)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"     # PII_ENCRYPTION_KEY
# node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"  # SEED_ADMIN_PASSWORD
#
# ─── Provider account checklist (in this order) ────────────────────
#  1. Neon Postgres   → DATABASE_URL + DIRECT_URL (mandatory)
#  2. Stripe          → STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET (test mode for closed beta)
#  3. Resend          → skip (RESEND_API_KEY="") — emails console-log
#  4. R2              → skip (R2_*="") — base64 fallback works
#  5. Sentry          → skip (SENTRY_DSN="") — Railway logs suffice

NODE_ENV="production"
PORT="4000"

# ── Database (Neon production) ────────────────────────────────────
# Pooled (PgBouncer) URL for the app.
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.region.aws.neon.tech/getx?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=10&pool_timeout=20"
# Non-pooled URL for `prisma migrate deploy` (DDL).
DIRECT_URL="postgresql://USER:PASS@HOST.region.aws.neon.tech/getx?sslmode=require&channel_binding=require"

# ── JWT (CRITICAL) ────────────────────────────────────────────────
# Generate with:  openssl rand -base64 48
# Use TWO different secrets — token rotation depends on this.
JWT_ACCESS_SECRET="REPLACE_WITH_48_BYTE_RANDOM"
JWT_REFRESH_SECRET="REPLACE_WITH_48_BYTE_RANDOM_DIFFERENT_FROM_ACCESS"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── Encryption (PII) ──────────────────────────────────────────────
PII_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_HEX"

# ── Cookies ───────────────────────────────────────────────────────
# .getx.gg in prod (cross-subdomain SSO across web/seller/admin).
COOKIE_DOMAIN=".getx.gg"

# ── Frontend URLs (CORS allowlist + WebSocket origin allowlist) ───
WEB_URL="https://getx.gg"
SELLER_URL="https://sell.getx.gg"
ADMIN_URL="https://admin.getx.gg"
API_URL="https://api.getx.gg"

# ── Email (Resend) — OPTIONAL ─────────────────────────────────────
# Leave RESEND_API_KEY blank for closed beta — transactional emails
# (verify, order updates) will be console-logged instead.
# When ready: resend.com → API Keys + verified domain (SPF/DKIM/DMARC).
RESEND_API_KEY=""
RESEND_FROM_EMAIL="GETX <noreply@getx.live>"

# ── Image storage (Cloudflare R2) ─────────────────────────────────
# Leave the four R2_* blanks to use base64 data-URL fallback (P10 dev mode).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="getx-uploads"
R2_PUBLIC_URL="https://getx-uploads.r2.dev"

# ── Payments — PRIMARY: Stripe ────────────────────────────────────
# GETX picks Stripe as the primary global processor (2.9% + $0.30/txn).
# When STRIPE_SECRET_KEY is present, the API auto-selects Stripe for
# every checkout. Leave EMPTY to fall back to the mock provider (safe
# for closed-beta — fake checkout flow, no real card movement).
#
# Dashboard:  https://dashboard.stripe.com/apikeys
# Webhook configure at:
#   https://dashboard.stripe.com/webhooks
# Webhook endpoint URL (set in Stripe dashboard):
#   https://api.getx.gg/api/v1/payments/webhook/stripe
# Events to subscribe:
#   checkout.session.completed
#   payment_intent.succeeded
#   payment_intent.payment_failed
#   charge.refunded
#   charge.dispute.created
#
# Test mode keys start with sk_test_ / whsec_ — safe to use during
# soft-launch. Swap to sk_live_ / whsec_ for public launch.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Stripe Connect webhook (sellers' payout pipeline) ─────────────
# Separate signing secret for /payouts/connect/webhook. Falls back to
# STRIPE_WEBHOOK_SECRET when unset.
STRIPE_CONNECT_WEBHOOK_SECRET=""

# Stripe is the only checkout provider. Card + wallet + UPI + iDEAL +
# SEPA + dozens more rails are activated per buyer's billing country
# from the Stripe dashboard — no other PSP env vars needed.

# ── Production seed ───────────────────────────────────────────────
# Used by `pnpm --filter @getx/database seed:prod`. Only consumed once
# (creates the first SUPER_ADMIN if none exists). Rotate the password
# immediately via /admin/users after first login.
SEED_ADMIN_EMAIL="admin@getx.gg"
SEED_ADMIN_PASSWORD="REPLACE_WITH_24_BYTE_RANDOM"

# ── Optional: error tracking (Sentry) ─────────────────────────────
# Leave blank to skip — errors will still show in Railway/Render logs.
# When ready: sentry.io → Project → Settings → Client Keys (DSN).
SENTRY_DSN=""
