# GETX API — production env template.
# Copy to your hosting provider's secret store (Railway/Render dashboard).
# Never commit a populated copy — secrets only.

NODE_ENV="production"
PORT="4000"

# ── Database (Neon production) ────────────────────────────────────
# Pooled (PgBouncer) URL for the app.
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.region.aws.neon.tech/getx?sslmode=require&channel_binding=require&pgbouncer=true&connection_limit=10&pool_timeout=20"
# Non-pooled URL for `prisma migrate deploy` (DDL).
DIRECT_URL="postgresql://USER:PASS@HOST.region.aws.neon.tech/getx?sslmode=require&channel_binding=require"

# ── JWT (CRITICAL) ────────────────────────────────────────────────
# Generate with:  openssl rand -base64 48
# Use TWO different secrets — token rotation depends on this.
JWT_ACCESS_SECRET="REPLACE_WITH_48_BYTE_RANDOM"
JWT_REFRESH_SECRET="REPLACE_WITH_48_BYTE_RANDOM_DIFFERENT_FROM_ACCESS"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── Encryption (PII) ──────────────────────────────────────────────
PII_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_HEX"

# ── Cookies ───────────────────────────────────────────────────────
# .getx.gg in prod (cross-subdomain SSO across web/seller/admin).
COOKIE_DOMAIN=".getx.gg"

# ── Frontend URLs (CORS allowlist + WebSocket origin allowlist) ───
WEB_URL="https://getx.gg"
SELLER_URL="https://sell.getx.gg"
ADMIN_URL="https://admin.getx.gg"
API_URL="https://api.getx.gg"

# ── Email (Resend) ────────────────────────────────────────────────
# Get from resend.com — verify the from-domain DNS first.
# Leave RESEND_API_KEY blank to fall back to console-logged emails (dev mode).
RESEND_API_KEY="re_REPLACE"
RESEND_FROM_EMAIL="GETX <noreply@getx.gg>"

# ── Image storage (Cloudflare R2) ─────────────────────────────────
# Leave the four R2_* blanks to use base64 data-URL fallback (P10 dev mode).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="getx-uploads"
R2_PUBLIC_URL="https://getx-uploads.r2.dev"

# ── Payments (Paddle) ─────────────────────────────────────────────
# LEAVE PADDLE_API_KEY EMPTY for closed-beta launch — the mock provider
# handles checkout-flow testing without real card movement.
# Set when ready to take real payments. Configure webhook in Paddle:
#   https://api.getx.gg/api/v1/payments/webhook
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
PADDLE_ENV="production"

# ── Production seed ───────────────────────────────────────────────
# Used by `pnpm --filter @getx/database seed:prod`. Only consumed once
# (creates the first SUPER_ADMIN if none exists). Rotate the password
# immediately via /admin/users after first login.
SEED_ADMIN_EMAIL="admin@getx.gg"
SEED_ADMIN_PASSWORD="REPLACE_WITH_24_BYTE_RANDOM"

# ── Optional: error tracking ──────────────────────────────────────
SENTRY_DSN=""
