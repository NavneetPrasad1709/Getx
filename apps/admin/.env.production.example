# GETX admin app — production env template (Vercel).

# Keep RELATIVE (same-origin proxy) — an absolute value breaks Safari cookies.
NEXT_PUBLIC_API_URL=/api/v1
# REQUIRED: the admin middleware session check + /api rewrite proxy here.
API_UPSTREAM_URL=https://api.getx.live

NEXT_PUBLIC_WEB_URL=https://getx.live
NEXT_PUBLIC_ADMIN_URL=https://admin.getx.live
NEXT_PUBLIC_SITE_URL=https://admin.getx.live

NEXT_PUBLIC_SENTRY_DSN=
