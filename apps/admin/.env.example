# GETX admin app — local dev env template.
#
# Same-origin proxy: browser → /api/v1 → (Next rewrite) → API_UPSTREAM_URL.
# Keep NEXT_PUBLIC_API_URL relative (or include the /api/v1 path) or every
# admin API call 404s.
NEXT_PUBLIC_API_URL=/api/v1
# Server-side: the admin middleware session check + /api rewrite proxy here.
API_UPSTREAM_URL=http://localhost:4000

NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
