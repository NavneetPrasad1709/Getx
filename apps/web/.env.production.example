# GETX web app — production env template (Vercel).
# Set these in the Vercel project's environment settings.

# IMPORTANT: keep this RELATIVE. The browser calls /api/v1 same-origin and
# Next.js rewrites it to API_UPSTREAM_URL. An absolute cross-origin value here
# re-breaks Safari/iOS login (ITP drops the cross-site session cookie).
NEXT_PUBLIC_API_URL=/api/v1
# Server-side: where /api/* is proxied to (the NestJS API origin). REQUIRED.
API_UPSTREAM_URL=https://api.getx.live
# Chat WebSocket connects to the API directly (WS can't use the HTTP rewrite).
NEXT_PUBLIC_API_DIRECT_URL=https://api.getx.live

NEXT_PUBLIC_WEB_URL=https://getx.live
NEXT_PUBLIC_SELLER_URL=https://sell.getx.live
NEXT_PUBLIC_ADMIN_URL=https://admin.getx.live
NEXT_PUBLIC_SITE_URL=https://getx.live

# Buyer checkout kill-switch. Keep DISABLED (=true) until Stripe is live AND
# payment reliability (Phase 4) is verified — false enables REAL charges.
NEXT_PUBLIC_CHECKOUT_DISABLED=true

# Optional — enables client-side Sentry if set.
NEXT_PUBLIC_SENTRY_DSN=
