# GETX web app — local dev env template.
#
# The browser calls the API SAME-ORIGIN via the Next.js /api rewrite
# (next.config.mjs). Keep NEXT_PUBLIC_API_URL RELATIVE so the session cookie
# stays first-party — Safari/iOS ITP blocks cross-site cookies, so an absolute
# cross-origin value here silently breaks login.
NEXT_PUBLIC_API_URL=/api/v1
# Server-side only: where the /api/* rewrite proxies to (the NestJS API origin).
API_UPSTREAM_URL=http://localhost:4000
# Chat WebSocket can't go through the HTTP rewrite — it connects directly.
NEXT_PUBLIC_API_DIRECT_URL=http://localhost:4000

NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_SELLER_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Buyer checkout kill-switch. Keep it DISABLED (=true) until Stripe is live AND
# payment reliability (Phase 4) is verified — flipping to false enables REAL
# charges. While disabled the checkout CTA captures launch intent instead.
NEXT_PUBLIC_CHECKOUT_DISABLED=true
