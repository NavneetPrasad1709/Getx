# Pooled connection (used by app at runtime). connection_limit=10 for persistent
# NestJS server; pgbouncer=true disables prepared statements for transaction mode.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-1.aws.neon.tech/getx?sslmode=require&pgbouncer=true&connection_limit=10&pool_timeout=20"

# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/getx?sslmode=require"
